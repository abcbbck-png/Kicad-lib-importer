+void LIB_TREE_MODEL_ADAPTER::SetGroupColumn( const wxString& aColumn )
+{
+    if( m_groupByColumn == aColumn )
+        return;
+
+    m_groupByColumn = aColumn;
+    rebuildGroupNodes();
+
+    Freeze();
+    BeforeReset();
+    m_tree.SortNodes( m_sort_mode == BEST_MATCH );
+    AfterReset();
+    Thaw();
+
+    ShowResults();
+
+#ifdef __WXGTK__
+    m_widget->Refresh();
+    m_widget->Update();
+#endif
+}
