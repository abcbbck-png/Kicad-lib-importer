+bool LIB_TREE_MODEL_ADAPTER::GetColumnName( int aColIdx, wxString& aName ) const
+{
+    auto it = m_colIdxMap.find( (unsigned) aColIdx );
+
+    if( it != m_colIdxMap.end() )
+    {
+        aName = it->second;
+        return true;
+    }
+
+    return false;
+}
+
+
+void LIB_TREE_MODEL_ADAPTER::flattenGroups()
+{
+    for( std::unique_ptr<LIB_TREE_NODE>& lib : m_tree.m_Children )
+    {
+        if( lib->m_Type != LIB_TREE_NODE::TYPE::LIBRARY )
+            continue;
+
+        LIB_TREE_NODE::PTR_VECTOR newChildren;
+
+        for( auto& child : lib->m_Children )
+        {
+            if( child->m_Type == LIB_TREE_NODE::TYPE::GROUP )
+            {
+                // Move items from GROUP back into LIBRARY
+                for( auto& item : child->m_Children )
+                {
+                    item->m_Parent = lib.get();
+                    newChildren.push_back( std::move( item ) );
+                }
+            }
+            else
+            {
+                newChildren.push_back( std::move( child ) );
+            }
+        }
+
+        lib->m_Children = std::move( newChildren );
+    }
+}
+
+
+void LIB_TREE_MODEL_ADAPTER::rebuildGroupNodes()
+{
+    // Always start by flattening any existing grouping
+    flattenGroups();
+
+    if( m_groupByColumn.IsEmpty() )
+        return;
+
+    for( std::unique_ptr<LIB_TREE_NODE>& lib : m_tree.m_Children )
+    {
+        if( lib->m_Type != LIB_TREE_NODE::TYPE::LIBRARY )
+            continue;
+
+        // Build a map: groupKey -> list of indices
+        std::map<wxString, std::vector<size_t>> groupMap;
+
+        for( size_t i = 0; i < lib->m_Children.size(); ++i )
+        {
+            LIB_TREE_NODE* item = lib->m_Children[i].get();
+
+            if( item->m_Type != LIB_TREE_NODE::TYPE::ITEM )
+                continue;
+
+            wxString key;
+
+            if( m_groupByColumn == wxT( "Description" ) )
+                key = item->m_Desc;
+            else if( item->m_Fields.count( m_groupByColumn ) )
+                key = item->m_Fields.at( m_groupByColumn );
+
+            if( key.IsEmpty() )
+                key = _( "(ungrouped)" );
+
+            groupMap[key].push_back( i );
+        }
+
+        // If all items fall into one group, don't bother grouping
+        if( groupMap.size() <= 1 )
+            continue;
+
+        // Create GROUP nodes and move ITEM nodes into them
+        LIB_TREE_NODE::PTR_VECTOR newChildren;
+
+        // Preserve any non-ITEM children first (shouldn't happen, but be safe)
+        for( auto& child : lib->m_Children )
+        {
+            if( child && child->m_Type != LIB_TREE_NODE::TYPE::ITEM )
+                newChildren.push_back( std::move( child ) );
+        }
+
+        for( auto& [groupName, indices] : groupMap )
+        {
+            auto group = std::make_unique<LIB_TREE_NODE_GROUP>( lib.get(), groupName );
+
+            for( size_t idx : indices )
+            {
+                if( lib->m_Children[idx] )
+                    group->AddChild( std::move( lib->m_Children[idx] ) );
+            }
+
+            // Propagate existing scores from children so GetChildren() doesn't
+            // filter out the new GROUP node (it checks m_Score > 0).
+            for( const auto& child : group->m_Children )
+                group->m_Score = std::max( group->m_Score, child->m_Score );
+
+            group->AssignIntrinsicRanks();
+            newChildren.push_back( std::move( group ) );
+        }
+
+        lib->m_Children = std::move( newChildren );
+    }
+}
