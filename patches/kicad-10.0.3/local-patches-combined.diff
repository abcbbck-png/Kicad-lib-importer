 {
+    // Flatten any GROUP nodes back to direct ITEM children before syncing.
+    // Groups will be rebuilt at the end of Sync() via rebuildGroupNodes().
+    {
+        LIB_TREE_NODE::PTR_VECTOR flatChildren;
+
+        for( auto& child : aLibNode.m_Children )
+        {
+            if( child->m_Type == LIB_TREE_NODE::TYPE::GROUP )
+            {
+                for( auto& item : child->m_Children )
+                {
+                    item->m_Parent = &aLibNode;
+                    flatChildren.push_back( std::move( item ) );
+                }
+            }
+            else
+            {
+                flatChildren.push_back( std::move( child ) );
+            }
+        }
+
+        aLibNode.m_Children = std::move( flatChildren );
+    }
+
