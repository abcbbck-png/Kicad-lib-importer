From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: local <local>
Date: Tue, 28 Apr 2026 11:30:00 +0300
Subject: [PATCH] eeschema: expose bus entry size in properties

Add Size X and Size Y properties for schematic bus entries.

KiCad already stores bus entry geometry as SCH_BUS_ENTRY_BASE::m_size and
uses that vector for drawing, hit testing, plotting, serialization, and
connectivity endpoints.  This patch exposes the two vector components through
the property manager so a selected bus entry can be resized from the normal
properties UI instead of only by tool defaults or internal state.

The change is intentionally small:

- adds GetSizeX/SetSizeX and GetSizeY/SetSizeY wrappers around m_size
- registers Size X and Size Y as PT_SIZE properties for SCH_BUS_ENTRY_BASE

diff --git a/eeschema/sch_bus_entry.cpp b/eeschema/sch_bus_entry.cpp
index ea988758..b36d8036 100644
--- a/eeschema/sch_bus_entry.cpp
+++ b/eeschema/sch_bus_entry.cpp
@@ -677,5 +677,13 @@ static struct SCH_BUS_ENTRY_DESC
         propMgr.AddProperty( new PROPERTY<SCH_BUS_ENTRY_BASE, COLOR4D>(
                 _HKI( "Color" ), &SCH_BUS_ENTRY_BASE::SetBusEntryColor,
                 &SCH_BUS_ENTRY_BASE::GetBusEntryColor ) );
+
+        propMgr.AddProperty( new PROPERTY<SCH_BUS_ENTRY_BASE, int>( _HKI( "Size X" ),
+                    &SCH_BUS_ENTRY_BASE::SetSizeX, &SCH_BUS_ENTRY_BASE::GetSizeX,
+                    PROPERTY_DISPLAY::PT_SIZE ) );
+
+        propMgr.AddProperty( new PROPERTY<SCH_BUS_ENTRY_BASE, int>( _HKI( "Size Y" ),
+                    &SCH_BUS_ENTRY_BASE::SetSizeY, &SCH_BUS_ENTRY_BASE::GetSizeY,
+                    PROPERTY_DISPLAY::PT_SIZE ) );
     }
 } _SCH_BUS_ENTRY_DESC;
diff --git a/eeschema/sch_bus_entry.h b/eeschema/sch_bus_entry.h
index 3df32296..1d242ff6 100644
--- a/eeschema/sch_bus_entry.h
+++ b/eeschema/sch_bus_entry.h
@@ -73,6 +73,11 @@ public:
     VECTOR2I GetSize() const { return m_size; }
     void SetSize( const VECTOR2I& aSize ) { m_size = aSize; }
 
+    int GetSizeX() const { return m_size.x; }
+    void SetSizeX( int aX ) { m_size.x = aX; }
+    int GetSizeY() const { return m_size.y; }
+    void SetSizeY( int aY ) { m_size.y = aY; }
+
     // Base class getter unused; necessary for property to compile
     int GetPenWidth() const override;
     void SetPenWidth( int aWidth );
