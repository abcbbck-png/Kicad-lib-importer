+void LIB_TREE_NODE_GROUP::AddChild( std::unique_ptr<LIB_TREE_NODE> aChild )
+{
+    aChild->m_Parent = this;
+    m_Children.push_back( std::move( aChild ) );
+}
+
+
+void LIB_TREE_NODE_GROUP::UpdateScore(
+        const std::vector<std::unique_ptr<EDA_COMBINED_MATCHER>>& aMatchers,
+        std::function<bool( LIB_TREE_NODE& aNode )>* aFilter )
+{
+    m_Score = 0;
+
+    for( std::unique_ptr<LIB_TREE_NODE>& child : m_Children )
+    {
+        child->UpdateScore( aMatchers, aFilter );
+        m_Score = std::max( m_Score, child->m_Score );
+    }
+}
